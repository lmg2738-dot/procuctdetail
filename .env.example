# OpenRouter (무료 모델만 사용)
OPENROUTER_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:50005

# Optional: 비전 모델 고정 (openrouter.ai/models 에서 무료 비전 모델 ID 확인)
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-exp:free

# Optional: AI 썸네일 이미지 생성 (느리고 rate limit 잦음, 기본 비활성)
# ENABLE_THUMBNAIL_IMAGE=true
